<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/picker_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/picker_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        android:background="@drawable/picker_card_bg"
        android:clickable="true"
        android:elevation="16dp"
        android:focusable="true"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/picker_title"
            android:textColor="#FFFFFFFF"
            android:textSize="19sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="3dp"
            android:paddingBottom="16dp"
            android:text="@string/picker_subtitle"
            android:textColor="#B3FFFFFF"
            android:textSize="13sp" />

        <!-- Mode toggle: Duration | Alarm -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tab_duration"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/chip_accent_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tab_alarm"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:background="@drawable/chip_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Duration mode -->
        <LinearLayout
            android:id="@+id/section_duration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chip_5"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/chip_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:textColor="#FFFFFFFF"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/chip_10"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/chip_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:textColor="#FFFFFFFF"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/chip_15"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/chip_bg"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:textColor="#FFFFFFFF"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingTop="12dp">

                <NumberPicker
                    android:id="@+id/custom_wheel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:id="@+id/minutes_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="@string/picker_minutes_label"
                    android:textColor="#FFFFFFFF"
                    android:textSize="16sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_start_duration"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/chip_accent_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/picker_custom_start"
                android:textColor="#FFFFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Alarm mode -->
        <LinearLayout
            android:id="@+id/section_alarm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TimePicker
                android:id="@+id/time_picker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:timePickerMode="spinner" />

            <TextView
                android:id="@+id/btn_start_alarm"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/chip_accent_bg"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/picker_set_alarm"
                android:textColor="#FFFFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingTop="18dp"
            android:paddingBottom="4dp"
            android:text="@string/picker_cancel"
            android:textColor="#FFFF8A80"
            android:textSize="15sp"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
