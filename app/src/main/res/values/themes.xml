<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Pause" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Dark theme used only when inflating the overlay picker, so the platform
         NumberPicker / TimePicker spinners render light text on the dark card. -->
    <style name="Theme.Pause.Overlay" parent="android:Theme.Material.NoActionBar">
        <item name="android:colorAccent">#FF7C5CFF</item>
        <item name="android:textColorPrimary">#FFFFFFFF</item>
        <item name="android:textColorSecondary">#B3FFFFFF</item>
    </style>
</resources>
